# Backend API base URL (server-side, not exposed to the browser)
API_BASE_URL=http://localhost:8009/api/v1

# Backend API base URL (browser-side, must start with NEXT_PUBLIC_)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8009/api/v1

# Secret key for signing the session cookie (HMAC-SHA256).
# Must be at least 32 characters. REQUIRED in production.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
